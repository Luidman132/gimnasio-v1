# Copiar este archivo a ".env" en el servidor y completar los valores.
# El archivo .env NUNCA se sube a git (ya está en .gitignore).

# Contraseña de root de MySQL (obligatoria). Usar una contraseña fuerte
# y DISTINTA a la que estuvo publicada en el repositorio.
DB_PASS=

# Nombre de la base de datos
DB_NAME=tramusagym_db

# Puerto donde se sirve la aplicación web en la red
PUERTO_WEB=9000

# Orígenes adicionales permitidos para llamar a la API directamente
# (solo para desarrollo; en producción el proxy /api no necesita CORS)
ALLOWED_ORIGINS=http://localhost:5173

# Dónde se expone phpMyAdmin.
#   127.0.0.1  → solo desde el propio servidor (RECOMENDADO, seguro)
#   0.0.0.0    → accesible desde toda la red de la empresa (como antes)
PMA_BIND=127.0.0.1
